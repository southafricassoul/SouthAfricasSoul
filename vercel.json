{
  "version": 2,
  "routes": [
    {
      "src": "/api/chat",
      "dest": "/api/chat.cjs"
    },
    {
      "src": "/api/webhook/whatsapp",
      "dest": "/api/webhook/whatsapp.cjs"
    },
    {
      "src": "/api/webhook/telegram",
      "dest": "/api/webhook/telegram.cjs"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
