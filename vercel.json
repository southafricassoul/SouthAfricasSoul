{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/chat",
      "destination": "/api/chat.js"
    },
    {
      "source": "/api/webhook/whatsapp",
      "destination": "/api/webhook/whatsapp.js"
    },
    {
      "source": "/api/webhook/telegram",
      "destination": "/api/webhook/telegram.js"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "vercel-node@latest"
    }
  }
}